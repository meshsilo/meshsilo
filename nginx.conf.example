# Silo Nginx Configuration Example
# Copy and adjust this configuration for your server

server {
    listen 80;
    server_name silo.example.com;

    # Redirect HTTP to HTTPS (recommended)
    # return 301 https://$server_name$request_uri;

    root /var/www/silo;
    index index.php;

    # Security: Deny access to sensitive files
    location ~ /\.(git|claude|htaccess) {
        deny all;
        return 404;
    }

    location ~ \.(db|sqlite|sql|log)$ {
        deny all;
        return 404;
    }

    location = /config.local.php {
        deny all;
        return 404;
    }

    # Deny direct access to app/ and storage/ directories
    location ~ ^/app/ {
        deny all;
        return 404;
    }

    location ~ ^/storage/ {
        deny all;
        return 404;
    }

    # Allow access to uploaded assets
    location /assets/ {
        try_files $uri =404;
        expires 1w;
        add_header Cache-Control "public";
    }

    # Serve public directory files (sw.js, manifest.json, etc.)
    location = /sw.js {
        alias /var/www/silo/public/sw.js;
        add_header Cache-Control "no-cache";
        add_header Service-Worker-Allowed "/";
    }

    location = /manifest.json {
        alias /var/www/silo/public/manifest.json;
        add_header Cache-Control "no-cache";
    }

    # Friendly URLs - route all requests through index.php
    location / {
        try_files $uri $uri/ /index.php?route=$uri&$args;
    }

    # PHP processing
    location ~ \.php$ {
        fastcgi_pass unix:/var/run/php/php-fpm.sock;
        # Or use TCP: fastcgi_pass 127.0.0.1:9000;

        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        include fastcgi_params;

        # Increase timeouts for large file uploads
        fastcgi_read_timeout 300;
    }

    # Large file upload support
    client_max_body_size 100M;

    # Security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Static file caching
    location ~* \.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # 3D model files - no caching, allow downloads
    location ~* \.(stl|3mf|obj|step)$ {
        expires -1;
        add_header Cache-Control "no-cache";
    }
}

# HTTPS server block (recommended for production)
# server {
#     listen 443 ssl http2;
#     server_name silo.example.com;
#
#     ssl_certificate /etc/letsencrypt/live/silo.example.com/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/silo.example.com/privkey.pem;
#
#     # ... rest of configuration same as above ...
# }

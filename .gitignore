# Storage directory (persistent data)
storage/assets/*
!storage/assets/.gitkeep
storage/db/*.db
storage/logs/*
!storage/logs/.gitkeep
storage/cache/*
!storage/cache/.gitkeep
storage/demo-seed/
storage/.encryption_key

# Generated version file (created by Docker build / git describe)
VERSION

# Local configuration
config.local.php
storage/db/config.local.php

# Legacy paths (backward compatibility during migration)
db/*.db
assets/*
logs/*
cache/*

# IDE
.idea/
.vscode/
*.swp
*.swo
*.kate-swp

# OS
.DS_Store
Thumbs.db

# PHP
vendor/
.phpunit.cache/
*.log

# Plugins (user-installed, not part of core)
plugins/

# Documentation (hosted on main website)
docs/

# Development files
.claude/
todo.txt
mcp_servers.json

# Tests (local development only)
tests/
phpunit.xml

# License tools (keep private keys secure)
cli/generate-license.php
cli/LICENSE-TOOLS-README.md
cli/*.pem
cli/license-*.txt
CLAUDE.md
**/CLAUDE.md

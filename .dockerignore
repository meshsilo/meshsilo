# Git
.git
.gitignore

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~

# Local configuration (will be generated or mounted)
config.local.php
**/config.local.php

# Runtime data (should be mounted as volumes)
storage/assets/*
!storage/assets/.gitkeep
storage/db/*.db
storage/db/config.local.php
storage/logs/*
!storage/logs/.gitkeep
storage/cache/*
storage/uploads/*
storage/demo-seed/
storage/db/*.db-wal
storage/db/*.db-shm

# Secrets - MUST NOT be baked into an image layer
.env
.env.*
storage/.encryption_key

# Composer dependencies (no production require deps; excluding is safe)
vendor/

# Documentation (not needed in container)
*.md
!README.md
todo.txt

# Development files
.claude
.github
*.log
tests/
phpunit.xml

# Docker files (don't include in build context recursively)
docker-compose*.yml

# OS files
.DS_Store
Thumbs.db

# Silo Apache Configuration
# Enable this file by ensuring mod_rewrite is enabled

<IfModule mod_rewrite.c>
    RewriteEngine On

    # If you're running Silo in a subdirectory, uncomment and set the base path
    # RewriteBase /silo/

    # Block access to .git, .claude directories
    RewriteRule ^\.(?:git|claude)(/|$) - [F,L]

    # Block direct access to app/ directory (accessed via PHP router only)
    # First, redirect known .php paths to clean URLs
    RewriteCond %{THE_REQUEST} \s/app/admin/([a-zA-Z0-9_-]+)\.php(?:\?|\ |\s|$) [NC]
    RewriteRule ^app/admin/([a-zA-Z0-9_-]+)\.php$ /admin/$1 [R=302,L,QSA]

    RewriteCond %{THE_REQUEST} \s/app/pages/([a-zA-Z0-9_-]+)\.php(?:\?|\ |\s|$) [NC]
    RewriteRule ^app/pages/([a-zA-Z0-9_-]+)\.php$ /$1 [R=302,L,QSA]

    RewriteCond %{THE_REQUEST} \s/app/actions/([a-zA-Z0-9_-]+)\.php(?:\?|\ |\s|$) [NC]
    RewriteRule ^app/actions/([a-zA-Z0-9_-]+)\.php$ /actions/$1 [R=302,L,QSA]

    # Block any remaining direct access to app/ and storage/
    RewriteRule ^app/ - [F,L]
    RewriteRule ^storage/ - [F,L]

    # Serve PWA files from public directory
    RewriteRule ^sw\.js$ public/sw.js [L]
    RewriteRule ^manifest\.json$ public/manifest.json [L]

    # Don't rewrite requests for files or directories that exist
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Rewrite all other requests to index.php with the route parameter
    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>

# Protect database files
<FilesMatch "\.(db|sqlite|sql)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Protect log files
<FilesMatch "\.log$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Protect config files
<FilesMatch "^config\.local\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# =====================================================
# Browser Caching & Performance
# =====================================================

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Enable ETags for cache validation
<IfModule mod_headers.c>
    FileETag MTime Size
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On

    # Images - cache for 1 year (immutable)
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # CSS and JavaScript - cache for 1 year (we use ?v= versioning)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"

    # Fonts - cache for 1 year
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"

    # 3D model files - cache for 1 week (can be changed frequently)
    ExpiresByType model/stl "access plus 1 week"
    ExpiresByType model/obj "access plus 1 week"
    ExpiresByType model/gltf+json "access plus 1 week"
    ExpiresByType model/gltf-binary "access plus 1 week"
    ExpiresByType model/x3d+xml "access plus 1 week"
    ExpiresByType application/sla "access plus 1 week"
    ExpiresByType application/octet-stream "access plus 1 week"

    # HTML - no cache (dynamic pages)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Add Cache-Control headers for static assets
<IfModule mod_headers.c>
    # CSS and JS with version query strings - long cache
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Images - long cache
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Fonts - long cache
    <FilesMatch "\.(woff|woff2|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # 3D model files - moderate cache
    <FilesMatch "\.(stl|3mf|obj|ply|amf|gcode|glb|gltf|fbx|dae|blend|step|stp|iges|igs|3ds|dxf|off|x3d)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

# Disable directory listing
Options -Indexes

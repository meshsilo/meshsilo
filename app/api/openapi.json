          "creator": { "type": "string" },
          "collection": { "type": "string" },
          "source_url": { "type": "string" },
          "license": { "type": "string" },
          "print_type": { "type": "string" },
          "download_count": { "type": "integer" },
          "is_archived": { "type": "boolean" },
          "is_printed": { "type": "boolean" },
          "dimensions": {
            "type": "object",
            "properties": {

{
  "openapi": "3.0.3",
  "info": {
    "title": "Silo API",
    "description": "REST API for Silo - Digital Asset Manager for 3D Print Files\n\nSilo provides a comprehensive API for managing 3D models, categories, tags, collections, and system statistics.\n\n## Authentication\n\nAll API requests require authentication via API key. Include your API key in one of the following ways:\n\n1. **Header (recommended):** `X-API-Key: your-api-key`\n2. **Query parameter:** `?api_key=your-api-key`\n\nAPI keys can be created in the admin settings panel.\n\n## Permissions\n\nAPI keys have different permission levels:\n- **read**: View models, categories, tags, collections, and stats\n- **write**: Create and update models, tags, collections\n- **delete**: Delete models, tags, collections\n- **admin**: Full access including category management\n\n## Rate Limiting\n\nAPI requests are rate-limited to prevent abuse. Current limits are returned in response headers:\n- `X-RateLimit-Limit`: Maximum requests per window\n- `X-RateLimit-Remaining`: Remaining requests in current window\n- `X-RateLimit-Reset`: Timestamp when the window resets\n\n## Pagination\n\nList endpoints support pagination:\n- `page`: Page number (default: 1)\n- `limit`: Items per page (default: 20, max: 100)\n\nPaginated responses include metadata:\n```json\n{\n  \"data\": [...],\n  \"pagination\": {\n    \"page\": 1,\n    \"limit\": 20,\n    \"total\": 150,\n    \"total_pages\": 8\n  }\n}\n```",
    "version": "1.0.0",
    "contact": {
      "name": "Silo Support"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "/api",
      "description": "Silo API"
    }
  ],
  "security": [
    {
      "ApiKeyHeader": []
    },
    {
      "ApiKeyQuery": []
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "API Health Check",
        "description": "Returns API status and version",
        "tags": ["System"],
        "responses": {
          "200": {
            "description": "API is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "version": {
                      "type": "string",
                      "example": "1.0"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/models": {
      "get": {
        "summary": "List Models",
        "description": "Retrieve a paginated list of 3D models with optional filters",
        "tags": ["Models"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Search query (searches name, description, creator)",
            "schema": { "type": "string" }
          },
          {
            "name": "category_id",
            "in": "query",
            "description": "Filter by category ID",
            "schema": { "type": "integer" }
          },
          {
            "name": "tag_id",
            "in": "query",
            "description": "Filter by tag ID",
            "schema": { "type": "integer" }
          },
          {
            "name": "collection",
            "in": "query",
            "description": "Filter by collection name",
            "schema": { "type": "string" }
          },
          {
            "name": "file_type",
            "in": "query",
            "description": "Filter by file type",
            "schema": { "type": "string", "enum": ["stl", "3mf", "obj", "ply", "amf", "gcode", "glb", "gltf", "fbx", "dae", "blend", "step", "stp", "iges", "igs", "3ds", "dxf", "off", "x3d"] }
          },
          {
            "name": "print_type",
            "in": "query",
            "description": "Filter by print type",
            "schema": { "type": "string", "enum": ["fdm", "sla", "both"] }
          },
          {
            "name": "is_archived",
            "in": "query",
            "description": "Filter by archived status",
            "schema": { "type": "boolean" }
          },
          {
            "name": "is_printed",
            "in": "query",
            "description": "Filter by printed status",
            "schema": { "type": "boolean" }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order",
            "schema": {
              "type": "string",
              "enum": ["newest", "oldest", "name", "name_desc", "size", "downloads", "updated"],
              "default": "newest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of models",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelListResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "summary": "Upload Model",
        "description": "Upload a new 3D model file",
        "tags": ["Models"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The 3D model file (STL, 3MF, OBJ, PLY, AMF, GCODE, GLB, GLTF, FBX, DAE, BLEND, STEP, STP, IGES, IGS, 3DS, DXF, OFF, X3D, or ZIP archive)"
                  },
                  "name": {
                    "type": "string",
                    "description": "Model name (defaults to filename)"
                  },
                  "description": {
                    "type": "string"
                  },
                  "creator": {
                    "type": "string"
                  },
                  "collection": {
                    "type": "string"
                  },
                  "source_url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "license": {
                    "type": "string"
                  },
                  "print_type": {
                    "type": "string",
                    "enum": ["fdm", "sla", "both"]
                  },
                  "category_ids": {
                    "type": "string",
                    "description": "Comma-separated category IDs"
                  },
                  "tags": {
                    "type": "string",
                    "description": "Comma-separated tag names"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Model created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/models/{id}": {
      "get": {
        "summary": "Get Model",
        "description": "Retrieve a single model by ID",
        "tags": ["Models"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }

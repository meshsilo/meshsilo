# Silo Environment Configuration
# Copy this file to .env and update the values
#
# IMPORTANT FOR PRODUCTION:
# - Set APP_URL to your actual domain (e.g., https://silo.example.com)
# - Set APP_DEBUG=false
# - Set FORCE_HTTPS=true if using HTTPS
# - Configure proper database credentials if using MySQL
# - Set MAIL_* settings for email functionality

# ===========================================
# Application
# ===========================================
APP_NAME="Silo"
APP_ENV=production
APP_DEBUG=false
# IMPORTANT: Change this to your actual domain for production
# Use https:// prefix when behind a reverse proxy with SSL
APP_URL=http://localhost

# ===========================================
# Database
# ===========================================
# Supported: sqlite, mysql
# SQLite is recommended for single-server deployments
# MySQL is recommended for high-availability or multi-server setups
DB_TYPE=sqlite
# Path relative to application root (only for SQLite)
DB_PATH=db/silo.db

# MySQL settings (only needed if DB_TYPE=mysql)
# For production MySQL, use a strong password and restrict access
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=silo
DB_USERNAME=silo
DB_PASSWORD=

# ===========================================
# Authentication
# ===========================================
# Session lifetime in minutes
SESSION_LIFETIME=120

# Allow user registration
ALLOW_REGISTRATION=true

# Require email verification
REQUIRE_VERIFICATION=false

# ===========================================
# OIDC / SSO
# ===========================================
OIDC_ENABLED=false
OIDC_PROVIDER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=${APP_URL}/oidc-callback

# ===========================================
# SAML SSO
# ===========================================
SAML_ENABLED=false
SAML_IDP_METADATA_URL=
SAML_SP_ENTITY_ID=${APP_URL}
SAML_USERNAME_ATTRIBUTE=email
SAML_AUTO_REGISTER=true

# ===========================================
# LDAP / Active Directory
# ===========================================
LDAP_ENABLED=false
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(sAMAccountName={username})

# ===========================================
# Mail
# ===========================================
# Supported: mail, smtp, log
# - mail: Uses PHP's mail() function (requires local MTA like sendmail/postfix)
# - smtp: Direct SMTP connection (recommended for reliable delivery)
# - log: Logs emails to storage/logs/mail.log (for testing)
MAIL_DRIVER=mail

# SMTP settings (only needed if MAIL_DRIVER=smtp)
# Common providers: smtp.mailgun.org, smtp.sendgrid.net, smtp.gmail.com
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# Encryption: tls (port 587) or ssl (port 465)
MAIL_ENCRYPTION=tls

# From address - IMPORTANT: Use a valid domain you control
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Admin notification email - receives system alerts
ADMIN_EMAIL=

# ===========================================
# Storage
# ===========================================
# Upload path (relative to app root)
UPLOAD_PATH=assets

# Maximum file size in bytes (100MB default)
MAX_FILE_SIZE=104857600

# Allowed file extensions (3D models and archives)
ALLOWED_EXTENSIONS=stl,3mf,obj,ply,amf,gcode,glb,gltf,fbx,dae,blend,step,stp,iges,igs,3ds,dxf,off,x3d,zip

# ===========================================
# Cache
# ===========================================
# Supported: file, apcu
CACHE_DRIVER=file
CACHE_PREFIX=silo_

# ===========================================
# Queue
# ===========================================
# Default queue name
QUEUE_DEFAULT=default

# Queue worker sleep time (seconds)
QUEUE_SLEEP=3

# ===========================================
# Rate Limiting
# ===========================================
# API rate limit (requests per hour)
API_RATE_LIMIT=1000

# Login rate limit (attempts per minute)
LOGIN_RATE_LIMIT=5

# ===========================================
# Logging
# ===========================================
# Log level: debug, info, warning, error
LOG_LEVEL=info

# Log file path
LOG_PATH=logs

# ===========================================
# Security
# ===========================================
# CSRF token lifetime (minutes)
CSRF_LIFETIME=60

# Session cookie name
SESSION_COOKIE=silo_session

# Force HTTPS - IMPORTANT: Set to true for production with SSL
# This ensures all URLs are generated with https:// prefix
FORCE_HTTPS=false

# ===========================================
# Features
# ===========================================
# Enable API access
API_ENABLED=true

# Enable webhooks
WEBHOOKS_ENABLED=true

# Enable two-factor authentication
TWO_FACTOR_ENABLED=true

# Enable file deduplication
DEDUP_ENABLED=true

# ===========================================
# Thumbnails
# ===========================================
# Thumbnail quality (1-100)
THUMBNAIL_QUALITY=85

# Thumbnail max dimension
THUMBNAIL_SIZE=400

# ===========================================
# 3D Model Settings
# ===========================================
# Auto-analyze models on upload
AUTO_ANALYZE=true

# Auto-convert STL to 3MF
AUTO_CONVERT=false

# ===========================================
# Enterprise Features
# ===========================================
# License key for enterprise features
LICENSE_KEY=

# Enable audit logging
AUDIT_ENABLED=true

# Audit log retention (days, 0 = forever)
AUDIT_RETENTION=365

# ===========================================
# Production Checklist
# ===========================================
# Before deploying to production, ensure:
# 1. APP_URL is set to your actual domain with https://
# 2. APP_DEBUG is set to false
# 3. FORCE_HTTPS is set to true (if using SSL)
# 4. Database credentials are properly configured
# 5. MAIL_FROM_ADDRESS uses your domain
# 6. File permissions are correctly set (storage/ writable)

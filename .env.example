# Silo Environment Configuration
# Copy this file to .env and update the values

# ===========================================
# Application
# ===========================================
APP_NAME="Silo"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# ===========================================
# Database
# ===========================================
# Supported: sqlite, mysql
DB_TYPE=sqlite
DB_PATH=db/silo.db

# MySQL settings (only needed if DB_TYPE=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=silo
DB_USERNAME=silo
DB_PASSWORD=

# ===========================================
# Authentication
# ===========================================
# Session lifetime in minutes
SESSION_LIFETIME=120

# Allow user registration
ALLOW_REGISTRATION=true

# Require email verification
REQUIRE_VERIFICATION=false

# ===========================================
# OIDC / SSO
# ===========================================
OIDC_ENABLED=false
OIDC_PROVIDER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=${APP_URL}/oidc-callback

# ===========================================
# SAML SSO
# ===========================================
SAML_ENABLED=false
SAML_IDP_METADATA_URL=
SAML_SP_ENTITY_ID=${APP_URL}
SAML_USERNAME_ATTRIBUTE=email
SAML_AUTO_REGISTER=true

# ===========================================
# LDAP / Active Directory
# ===========================================
LDAP_ENABLED=false
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(sAMAccountName={username})

# ===========================================
# Mail
# ===========================================
# Supported: mail, smtp, log
MAIL_DRIVER=mail

# SMTP settings
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# From address
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Admin notification email
ADMIN_EMAIL=

# ===========================================
# Storage
# ===========================================
# Upload path (relative to app root)
UPLOAD_PATH=assets

# Maximum file size in bytes (100MB default)
MAX_FILE_SIZE=104857600

# Allowed file extensions
ALLOWED_EXTENSIONS=stl,3mf,gcode,zip,obj,step

# ===========================================
# Cache
# ===========================================
# Supported: file, apcu
CACHE_DRIVER=file
CACHE_PREFIX=silo_

# ===========================================
# Queue
# ===========================================
# Default queue name
QUEUE_DEFAULT=default

# Queue worker sleep time (seconds)
QUEUE_SLEEP=3

# ===========================================
# Rate Limiting
# ===========================================
# API rate limit (requests per hour)
API_RATE_LIMIT=1000

# Login rate limit (attempts per minute)
LOGIN_RATE_LIMIT=5

# ===========================================
# Logging
# ===========================================
# Log level: debug, info, warning, error
LOG_LEVEL=info

# Log file path
LOG_PATH=logs

# ===========================================
# Security
# ===========================================
# CSRF token lifetime (minutes)
CSRF_LIFETIME=60

# Session cookie name
SESSION_COOKIE=silo_session

# Force HTTPS
FORCE_HTTPS=false

# ===========================================
# Features
# ===========================================
# Enable API access
API_ENABLED=true

# Enable webhooks
WEBHOOKS_ENABLED=true

# Enable two-factor authentication
TWO_FACTOR_ENABLED=true

# Enable file deduplication
DEDUP_ENABLED=true

# ===========================================
# Thumbnails
# ===========================================
# Thumbnail quality (1-100)
THUMBNAIL_QUALITY=85

# Thumbnail max dimension
THUMBNAIL_SIZE=400

# ===========================================
# 3D Model Settings
# ===========================================
# Auto-analyze models on upload
AUTO_ANALYZE=true

# Auto-convert STL to 3MF
AUTO_CONVERT=false

# ===========================================
# Enterprise Features
# ===========================================
# License key for enterprise features
LICENSE_KEY=

# Enable audit logging
AUDIT_ENABLED=true

# Audit log retention (days)
AUDIT_RETENTION=365
